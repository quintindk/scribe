# --- Transport ---
SCRIBE_TRANSPORT=sse
SCRIBE_HOST=0.0.0.0
SCRIBE_PORT=8000

# --- Qdrant (shared with Miller) ---
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
CHAMBERLAIN_COLLECTION_PREFIX=chamberlain-

# --- Query embeddings (must match Miller!) ---
OPENAI_COMPATIBLE_API_BASE=http://localhost:1234/v1
OPENAI_COMPATIBLE_API_KEY=not-needed
OPENAI_COMPATIBLE_MODEL=text-embedding-nomic-embed-text-v1.5

# --- Behaviour ---
SCRIBE_DEFAULT_LIMIT=5
SCRIBE_MAX_LIMIT=25
LOG_LEVEL=INFO
