# --- Transport ---
SCRIBE_TRANSPORT=http
SCRIBE_HOST=0.0.0.0
SCRIBE_PORT=8000
SCRIBE_PATH=/mcp

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# --- Collection layout ---
# archive-*  -> Miller-managed, persistent corpus
# scratch-*  -> Scribe ingest_* tools, ephemeral
# memory-*   -> Scribe remember/recall, curated facts
SCRIBE_ARCHIVE_PREFIX=archive-
SCRIBE_SCRATCH_PREFIX=scratch-
SCRIBE_MEMORY_COLLECTION=memory-default
# Back-compat: if SCRIBE_ARCHIVE_PREFIX is unset, COLLECTION_PREFIX is used.
# COLLECTION_PREFIX=archive-

# --- Query embeddings (must match Miller!) ---
OPENAI_COMPATIBLE_API_BASE=http://localhost:1234/v1
OPENAI_COMPATIBLE_API_KEY=not-needed
OPENAI_COMPATIBLE_MODEL=text-embedding-nomic-embed-text-v1.5

# --- Search behaviour ---
SCRIBE_DEFAULT_LIMIT=5
SCRIBE_MAX_LIMIT=25

# --- Ingest (URL + path) ---
# Host directory bound read-only into the container at /drop. Only paths
# under /drop are accepted by ingest_path.
SCRIBE_DROP_DIR=./drop
# SSRF gate. Set true ONLY for local development against RFC1918 / loopback.
SCRIBE_INGEST_ALLOW_PRIVATE=false
SCRIBE_INGEST_MAX_BYTES=5242880
SCRIBE_INGEST_TIMEOUT=30
SCRIBE_INGEST_PATH_MAX_FILES=500
SCRIBE_INGEST_PATH_MAX_BYTES=26214400

# --- Chunking ---
SCRIBE_CHUNK_CHARS=1000
SCRIBE_CHUNK_OVERLAP=200

LOG_LEVEL=INFO
